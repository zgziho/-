<Window x:Class="WpfApp1.Views.FirmwareUpdate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WpfApp1.Views"
        mc:Ignorable="d"
        Title="固件升级"
        Height="400" Width="600"
        Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" BorderThickness="1" BorderBrush="#CCCCCC" Margin="10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 固件文件选择 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="固件文件:" VerticalContentAlignment="Center" Width="80"/>
                    <TextBox Width="350" Text="{Binding FirmwareFilePath}" IsReadOnly="True" Margin="5 0"/>
                    <Button Content="浏览" Width="80" Command="{Binding BrowseCommand}"/>
                </StackPanel>
                
                <!-- 设备信息 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="设备信息:" VerticalContentAlignment="Center" Width="80"/>
                    <TextBlock Text="{Binding DeviceInfo}" VerticalAlignment="Center" FontWeight="Bold" Width="350"/>
                    <Button Content="获取设备信息" Width="100" Command="{Binding GetDeviceInfoCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#CCCCCC" Margin="10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 升级进度条 -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                    <Label Content="升级进度:"/>
                    <ProgressBar Width="500" Height="20" Value="{Binding ProgressValue}"/>
                </StackPanel>
                
                <!-- 进度信息 -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <Label Content="进度信息:"/>
                    <TextBox x:Name="ProgressInfoTextBox" Text="{Binding ProgressInfo}" IsReadOnly="True" Height="60" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#CCCCCC" Margin="10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="开始升级" Command="{Binding StartUpdateCommand}" Height="35"/>
            </Grid>
        </Border>
    </Grid>
</Window>