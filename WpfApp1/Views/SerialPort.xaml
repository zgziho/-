<Window x:Class="WpfApp1.Views.Serialport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1.Views"
        mc:Ignorable="d"
        Title="串口连接" Height="300" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0">
    <Window.Resources>
        <ResourceDictionary>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="串口连接设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- 端口、数据位、停止位 -->
            <Border Grid.Row="1" BorderThickness="1" BorderBrush="#CCCCCC"  CornerRadius="20" Padding="10" Margin="0,5">
                <StackPanel Orientation="Horizontal">
                    <Label Content="端口:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailablePorts}" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              SelectedItem="{Binding SelectedPort}" 
                              Width="100"/>

                    <Label Content="数据位:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableDataBits}" 
                              SelectedItem="{Binding DataBit}" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              Width="100"/>

                    <Label Content="停止位:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableStopBits}" 
                              SelectedItem="{Binding StopBit}" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              Width="100"/>
                </StackPanel>
            </Border>

            <!-- 波特率、校验位 -->
            <Border Grid.Row="2" BorderThickness="1" BorderBrush="#CCCCCC"  CornerRadius="20" Padding="10" Margin="0,5">
                <StackPanel Orientation="Horizontal">
                    <Label Content="波特率:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableBaudRates}" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              SelectedItem="{Binding BaudRate}" 
                              Width="100"/>

                    <Label Content="校验位:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableParities}" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              SelectedItem="{Binding Parity}" 
                              Width="100"/>

                    <Label Content="超时时间:" Width="60" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableTimeouts}" 
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Center"
                              SelectedItem="{Binding Timeout}" 
                              Width="100"/>

                </StackPanel>
            </Border>

         

            <!-- 按钮区域 -->
            <Border Grid.Row="3"  Margin="0 5" CornerRadius="20" Padding="10" BorderThickness="1" BorderBrush="#CCCCCC">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"></ColumnDefinition>
                        <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        <ColumnDefinition Width="AUTO"></ColumnDefinition>
                        <ColumnDefinition Width="AUTO"></ColumnDefinition>
                        <ColumnDefinition Width="AUTO"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="当前状态:" FontWeight="Bold" Margin="10 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center"  FontSize="14"/>
                    <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" HorizontalAlignment="Left" VerticalAlignment="Center"  FontSize="13" FontWeight="Bold"/>

                    <Button Grid.Column="2" Content="自动检测波特率" Command="{Binding AutoDetectBaudRateCommand}" IsEnabled="{Binding IsAuto}"
                        Width="120" Height="auto"/>
                    <Button Grid.Column="3" Content="连接" Command="{Binding ConnectCommand}" 
                        Width="80"/>
                    <Button Grid.Column="4" Content="断开" Command="{Binding DisconnectCommand}" 
                            Width="80" Height="auto"
                            IsEnabled="{Binding IsConnected}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 自动检测波特率界面 -->
        <Grid Grid.Row="0"
              Visibility="{Binding IsAutoDetecting}">
            <Border BorderThickness="1"
                    BorderBrush="#CCCCCC"
                    Width="400" Height="250"
                    CornerRadius="10" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F0F0F0">
                <StackPanel Margin="20" VerticalAlignment="Center">
                    <TextBlock Text="自动检测波特率" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <Border BorderThickness="1" BorderBrush="#CCCCCC" Height="120" Margin="0,0,0,15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding DetectionLog}" 
                                       TextWrapping="Wrap" 
                                       Margin="10"
                                       FontSize="12"/>
                        </ScrollViewer>
                    </Border>

                    <Button Content="关闭" Command="{Binding CloseDetectionCommand}" 
                            Width="80" Height="30" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>

</Window>